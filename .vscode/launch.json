{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug all-6502-opcodes.s",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "-print-imm-hex",
                "-show-encoding",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\all-6502-opcodes.s"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug hello-world.s",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "-print-imm-hex",
                "-show-encoding",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\hello-world.s",
                "-I",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\Inputs",
                "-debug-only=asm-matcher"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug hello-world.s --filetype=obj",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "--filetype=obj",
                "-o=${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.obj",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\hello-world.s",
                "-I",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\Inputs"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug hello-world.s to obj",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "--filetype=obj",
                "-o=${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.obj",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\hello-world.s"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug modifiers.s",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/build/bin/llvm-mc.exe",
            "args": [
                "--filetype=obj",
                "-o=${workspaceFolder}\\build\\build\\test\\MC\\MOS\\Output\\modifiers.s.tmp.obj",
                "-triple",
                "mos",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\modifiers.s"
            ],
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}/build/build/bin",
            // "environment": [],
            // "externalConsole": false,
            // "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "llvm-objdump hello-world.s.tmp.obj",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-objdump.exe",
            "args": [
                "-D",
                "--all-headers",
                "--print-imm-hex",
                "${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.obj"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "lld hello-world.s.tmp.obj",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/lld.exe",
            "args": [
                "-flavor",
                "gnu",
                "${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.obj",
                "-o",
                "${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.elf",
                "-L",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\Inputs",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\Inputs\\c64.ld"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        }
  ]
}