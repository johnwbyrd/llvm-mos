{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [   
        {
            "name": "Debug llvm-objdump.exe",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/cmake/bin/llvm-objdump.exe",
            "args": ["--disassemble", "--triple=mos-unknown-unknown", "brk.o"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/cmake/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug llvm-mc.exe",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/cmake/bin/llvm-mc.exe",
            "args": ["--disassemble", "--triple=mos-unknown-unknown"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug llc.exe",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/cmake/bin/llc.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        }
    ]
}