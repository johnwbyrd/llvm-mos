{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "llvm-mc --mattr=help",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-mc.exe",
            "args": [
                "-arch=mos",
                "-mcpu=mos-generic",
                "-debug",
                "--mattr=help",
                "blank.s"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },

        {
            "name": "Debug all-6502-opcodes.s",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "-print-imm-hex",
                "-show-encoding",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\all-6502-opcodes.s"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug current assembly file with llvm-mc",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "-print-imm-hex",
                "-show-encoding",
                "${file}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug low-high-bytes.s",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-mc.exe",
            "args": [
                "-triple",
                "mos",
                "-print-imm-hex",
                "-show-encoding",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\low-high-bytes.s"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "Debug inst-ora.s",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-mc.exe",
            "args": [
                "-arch=mos",
                "-mcpu=mos-generic",
                "-show-encoding",
                "${workspaceFolder}\\llvm\\test\\MC\\MOS\\inst-ora.s"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "llvm-objdump hello-world.s.tmp.obj",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/llvm-objdump.exe",
            "args": [
                "-D",
                "--all-headers",
                "--print-imm-hex",
                "${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.obj"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
        {
            "name": "lld hello-world.s.tmp.obj",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/lld.exe",
            "args": [
                "-flavor",
                "gnu",
                "${workspaceFolder}\\build\\test\\MC\\MOS\\Output\\hello-world.s.tmp.obj"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "visualizerFile": "${workspaceFolder}/llvm/utils/LLVMVisualizers/llvm.natvis",
        },
   ]
}