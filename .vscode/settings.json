{
    "cmake.buildDirectory": "${workspaceRoot}/build/build",
    "cmake.installPrefix": "${workspaceRoot}/build/install",
    "cmake.sourceDirectory": "${workspaceRoot}/llvm",
    "cmake.generator": "Ninja",
    "cmake.configureSettings": {
        "LLVM_LIT_TOOLS_DIR": "c:/Program Files/Git/usr/bin/",
        "CMAKE_C_COMPILER_LAUNCHER": "sccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "sccache"
        },
    "cmake.autoRestartBuild": true,
    "cmake.buildBeforeRun": false,
    "files.associations": {
        "*.inc": "cpp",
        "memory": "cpp",
        "*.def": "cpp",
        "deque": "cpp",
        "list": "cpp",
        "vector": "cpp",
        "xstring": "cpp",
        "algorithm": "cpp"
    },
    "cmake.clearOutputBeforeBuild": true,
    "python.pythonPath": "C:\\Python38\\python.exe",
    "editor.rulers": [
        80,
        120
    ],
    "restructuredtext.confPath": "${workspaceFolder}\\llvm\\docs",
    "clangd.path": "C:/Program Files/LLVM/bin/clangd.exe",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceRoot}/build/build",
        "--clang-tidy",
        "--clang-tidy-checks=*,-modernize-use-trailing-return-type,-google-runtime-references"
    ],
    "lldb.executable": "c:/program files/llvm/bin/lldb.exe",
    "C_Cpp.autocomplete": "Disabled",
    "C_Cpp.default.intelliSenseMode": "clang-x64",
    "C_Cpp.enhancedColorization": "Enabled",
    "C_Cpp.intelliSenseEngine": "Disabled",
    "C_Cpp.clang_format_fallbackStyle": "LLVM",
    "C_Cpp.clang_format_style": "LLVM",
    "C_Cpp.workspaceParsingPriority": "low",
    "cmake.configureOnOpen": false,
    "files.eol": "\n", 
    "cmake.cacheInit": "../.vscode/llvm-mos.cmake"
}