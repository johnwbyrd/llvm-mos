{
    "cmake.buildDirectory": "${workspaceRoot}/build/cmake",
    "cmake.installPrefix": "${workspaceRoot}/build/cmake/install",
    "cmake.sourceDirectory": "${workspaceRoot}/llvm",
    "cmake.parallelJobs": 4,
    "cmake.generator": "Ninja",
    "cmake.useCMakeServer": false,
    "cmake.configureSettings": {
        "LLVM_TARGETS_TO_BUILD": "X86",
        "LLVM_OPTIMIZED_TABLEGEN": "1",
        "CMAKE_LINKER" : "C:/git/llvm-project/build/ninja-clang-release/bin/lld-link.exe"
    },
    "cmake.cacheInit": "../llvm-cache.cmake",
    "cmake.autoRestartBuild": true,
    "cmake.buildBeforeRun": false,
    "C_Cpp.default.compileCommands": "${workspaceRoot}/build/cmake/compile_commands.json",
    "C_Cpp.clang_format_fallbackStyle": "LLVM",
    "C_Cpp.clang_format_style": "LLVM",
    "C_Cpp.loggingLevel": "Debug",
    "files.associations": {
        "*.inc": "cpp",
        "memory": "cpp"
    },
    "C_Cpp.clang_format_sortIncludes": true,
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.cStandard": "c11",
    "C_Cpp.default.intelliSenseMode": "msvc-x64",
    "cmake.clearOutputBeforeBuild": false,
    "clang.executable": "c:/git/llvm-project/build/ninja-clang-release/install/bin/clang.exe"
}
