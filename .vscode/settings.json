{
    "cmake.buildDirectory": "${workspaceRoot}/build",
    "cmake.installPrefix": "${workspaceRoot}/build/install",
    "cmake.sourceDirectory": "${workspaceRoot}/llvm",
    "cmake.generator": "Ninja",
    "cmake.configureSettings": { 
        "LLVM_TARGETS_TO_BUILD": "X86",
        "LLVM_OPTIMIZED_TABLEGEN": "1",
        "CMAKE_INSTALL_PREFIX": "${workspaceRoot}/build/install",
        "LLVM_EXPERIMENTAL_TARGETS_TO_BUILD": ["MOS"],
        "LLVM_ENABLE_PROJECTS": ["clang", "lld"],
        "LIBXML2_LIBRARIES": "IGNORE",
        "CMAKE_AR": "C:/Program Files/LLVM/bin/llvm-ar.exe",
        "CMAKE_RANLIB": "C:/Program Files/LLVM/bin/llvm-ranlib.exe",
        "CMAKE_C_COMPILER": "C:/Program Files/LLVM/bin/clang-cl.exe",
        "CMAKE_CXX_COMPILER": "C:/Program Files/LLVM/bin/clang-cl.exe",
        "CMAKE_LINKER": "C:/Program Files/LLVM/bin/lld-link.exe",
        "LLVM_LIT_TOOLS_DIR": "c:/Program Files/Git/usr/bin/"
    },
    "cmake.autoRestartBuild": true,
    "cmake.buildBeforeRun": false,
    "files.associations": {
        "*.inc": "cpp",
        "memory": "cpp",
        "*.def": "cpp",
        "deque": "cpp",
        "list": "cpp",
        "vector": "cpp",
        "xstring": "cpp",
        "algorithm": "cpp"
    },
    "cmake.clearOutputBeforeBuild": true,
    "python.pythonPath": "C:\\Python38\\python.exe",
    "editor.rulers": [
        80,
        120
    ],
    "restructuredtext.confPath": "${workspaceFolder}\\llvm\\docs",
    "clangd.path": "C:/Program Files/LLVM/bin/clangd.exe",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceRoot}/build",
        "--clang-tidy",
        "--clang-tidy-checks=*,-modernize-use-trailing-return-type,-google-runtime-references,-fuchsia-default-arguments-calls"
    ],
    "lldb.executable": "c:/program files/llvm/bin/lldb.exe",
    "C_Cpp.autocomplete": "Disabled",
    "C_Cpp.default.intelliSenseMode": "clang-x64",
    "C_Cpp.enhancedColorization": "Enabled",
    "C_Cpp.intelliSenseEngine": "Disabled",
    "C_Cpp.clang_format_fallbackStyle": "LLVM",
    "C_Cpp.clang_format_style": "LLVM",
    "C_Cpp.workspaceParsingPriority": "low",
    "cmake.parallelJobs": 4,
    "cmake.buildEnvironment": {
    
    },
    "cmake.configureOnOpen": false,
}